{
  "manifest_version": 3,
  "name": "Gemini MapView",
  "version": "0.1.0",
  "description": "Maps the currently open Gemini chat into a pannable visual conversation view.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_title": "Gemini MapView",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
